#!/bin/bash
# Send a message to one or more teammate tmux panes as proper prompt input
# Usage: ./send [--from <name>] <pane|--all> <message>
# Example: ./send --all "Status check, everyone!"
# Example: ./send 0,2 "Reviewing my changes now."
#
# Uses flock to serialize tmux buffer access (prevents race conditions).
# Uses a named tmux buffer unique to this PID as extra safety.
# When --from is provided, the message is prefixed with "[<name>]: "

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
[ ! -f "$SCRIPT_DIR/team.conf" ] && { echo "ERROR: team.conf not found in $SCRIPT_DIR" >&2; exit 1; }
source "$SCRIPT_DIR/team.conf"

FROM=""
NO_LOG=0
while [ $# -gt 0 ]; do
  case "$1" in
    --from)
      FROM="$2"
      shift 2
      ;;
    --no-log)
      NO_LOG=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

TARGET_PANES="${1:-}"
shift || true
MSG="$*"

if [ -z "$MSG" ] || [ -z "$TARGET_PANES" ]; then
  echo "Usage: ./send [--from <name>] <pane|--all> <message>"
  echo "  Panes: ${PANE_CLAUDE}=${AGENT_CLAUDE}, ${PANE_GEMINI}=${AGENT_GEMINI}, ${PANE_CODEX}=${AGENT_CODEX}"
  exit 1
fi

TEAM_PANES="${PANE_LIST:-$PANE_CLAUDE $PANE_GEMINI $PANE_CODEX}"
CURRENT_TARGET=""
CURRENT_PANE=""
CURRENT_SESSION=""
if [ -n "$TMUX" ]; then
  # Use -t "$TMUX_PANE" to ensure we detect the ACTUAL pane we are in,
  # not just the 'active' pane in the window.
  CURRENT_TARGET=$(tmux display-message -t "$TMUX_PANE" -p '#S:#I' 2>/dev/null || true)
  CURRENT_PANE=$(tmux display-message -t "$TMUX_PANE" -p '#{pane_index}' 2>/dev/null || true)
  CURRENT_SESSION=$(tmux display-message -t "$TMUX_PANE" -p '#S' 2>/dev/null || true)
fi

# Determine the effective target window:
# 1. Use TMUX_TARGET from team.conf as the source of truth if set and not "auto".
# 2. If TMUX_TARGET is "auto", "current", or unset, use the current tmux window.
EFFECTIVE_TARGET="$TMUX_TARGET"
if [ "$TMUX_TARGET" = "auto" ] || [ "$TMUX_TARGET" = "current" ] || [ -z "$TMUX_TARGET" ]; then
  if [ -n "$CURRENT_TARGET" ]; then
    EFFECTIVE_TARGET="$CURRENT_TARGET"
  fi
fi

if [ -z "$EFFECTIVE_TARGET" ]; then
  echo "ERROR: TMUX_TARGET is not set in team.conf and not inside a tmux session." >&2
  exit 1
fi

# Prepend tmux info to the sender name if we are inside tmux.
if [ -n "$FROM" ] && [ -n "$CURRENT_SESSION" ] && [ -n "$CURRENT_PANE" ]; then
  # Format: "Name (session:pane)" e.g. "User (2:0.1)"
  FROM="$FROM ($CURRENT_SESSION:$CURRENT_PANE)"
fi

# Safety check: Warn if we are sending to a different window than the one we are in.
if [ -n "$CURRENT_TARGET" ] && [ "$CURRENT_TARGET" != "$EFFECTIVE_TARGET" ]; then
  echo "WARNING: Sending to target window $EFFECTIVE_TARGET while in $CURRENT_TARGET." >&2
fi

# Resolve --all to all teammates in the effective window, excluding the
# current pane if we are sending from within that same window.
if [ "$TARGET_PANES" = "--all" ]; then
  TARGET_PANES=""
  for pane in $TEAM_PANES; do
    if [ -n "$CURRENT_PANE" ] && [ "$CURRENT_TARGET" = "$EFFECTIVE_TARGET" ] && [ "$pane" = "$CURRENT_PANE" ]; then
      continue
    fi
    TARGET_PANES="${TARGET_PANES:+$TARGET_PANES,}$pane"
  done
fi

if [ -z "$TARGET_PANES" ]; then
  echo "ERROR: No recipient panes resolved for target $EFFECTIVE_TARGET." >&2
  exit 1
fi

format_target_id() {
  printf '%s.%s' "$EFFECTIVE_TARGET" "$1"
}

format_target_list() {
  local panes_csv="$1"
  local out=""
  local pane
  IFS=',' read -ra LIST <<< "$panes_csv"
  for pane in "${LIST[@]}"; do
    pane=$(echo "$pane" | xargs)
    [ -z "$pane" ] && continue
    out="${out:+$out,}$(format_target_id "$pane")"
  done
  printf '%s' "$out"
}

# Function to send to a single pane
send_to_pane() {
  local p="$1"
  local msg="$2"
  local from="$3"
  local target="$EFFECTIVE_TARGET.$p"
  local bufname="send_${$}_${p}"

  # Prefix with sender name if provided
  local display_msg="$msg"
  [ -n "$from" ] && display_msg="[$from]: $msg"

  if ! tmux display-message -p -t "$target" "#{pane_id}" >/dev/null 2>&1; then
    echo "ERROR: tmux target $target does not exist" >&2
    return 1
  fi

  gemini_capture_recent() {
    tmux capture-pane -t "$target" -p 2>/dev/null | tail -n 20
  }

  gemini_shell_mode_active() {
    gemini_capture_recent | grep -Eq '(shell mode enabled|^[[:space:]]*![[:space:]].*Type your shell command|^[[:space:]]*![[:space:]]*$)'
  }

  gemini_chat_mode_active() {
    gemini_capture_recent | tail -n 5 | grep -Eq '^[[:space:]]*\*[[:space:]]'
  }

  gemini_suggestion_active() {
    gemini_capture_recent | tail -n 10 | grep -Eq '(^[[:space:]]*>[[:space:]]|Queued \(press ↑ to edit\))'
  }

  gemini_input_prompt_active() {
    gemini_capture_recent | grep -Eq '(Type your message|@path/to/file|workspace \(/directory\)|✦)'
  }

  gemini_queue_active() {
    gemini_capture_recent | grep -Eq 'Queued \(press ↑ to edit\)'
  }

  gemini_overlay_active() {
    gemini_capture_recent | grep -Eq '(esc to cancel|Hide the startup banner|YOLO Ctrl\+Y|bypass permissions on)'
  }

  gemini_busy_active() {
    local title
    title=$(tmux display-message -p -t "$target" '#{pane_title}' 2>/dev/null || true)
    if printf '%s' "$title" | grep -Eq '(Working|Thinking|Loading|Running|Finalizing)'; then
      return 0
    fi
    if gemini_queue_active || gemini_overlay_active; then
      return 0
    fi
    return 1
  }

  reset_input() {
    if [ "$p" = "$GEMINI_PANE" ]; then
      # Respect Gemini's current mode. If it is in shell mode, fail cleanly
      # instead of forcing a mode switch. Busy chat mode is allowed because
      # Gemini CLI can queue a normal message after Enter.
      if gemini_shell_mode_active && ! gemini_chat_mode_active; then
        echo "ERROR: Gemini pane $p is in shell mode; not switching modes automatically" >&2
        return 1
      fi
      if ! gemini_input_prompt_active; then
        echo "ERROR: Gemini pane $p does not show the regular message prompt" >&2
        return 1
      fi
    fi

    # Clear any stale text in the current input line without changing modes.
    tmux send-keys -t "$target" C-u || return 1
    sleep 0.2
    return 0
  }

  reset_input || return 1

  if [ "$p" = "$GEMINI_PANE" ]; then
    tmux send-keys -t "$target" -l "$display_msg" || return 1
    sleep 0.3
    tmux send-keys -t "$target" Enter || return 1
  else
    printf '%s' "$display_msg" | tmux load-buffer -b "$bufname" - || return 1
    if ! tmux paste-buffer -b "$bufname" -t "$target"; then
      tmux delete-buffer -b "$bufname" 2>/dev/null
      return 1
    fi
    tmux delete-buffer -b "$bufname" 2>/dev/null
    sleep 0.4
    tmux send-keys -t "$target" Enter || return 1
  fi
  return 0
}

PROJECT_HASH=$(printf "%s" "$SCRIPT_DIR" | md5sum | cut -c1-8)
LOCKFILE="/tmp/team_${PROJECT_HASH}_tmux_send.lock"
FAILED_PANES=""
SENT_PANES=""
SEND_OK=1

# Acquire exclusive lock for the whole operation (multi-pane batch)
{
  flock -w 20 200 || {
    echo "ERROR: Could not acquire tmux send lock" >&2
    SEND_OK=0
  }

  if [ "$SEND_OK" -eq 1 ]; then
  # Split comma-separated panes
  IFS=',' read -ra ADDR <<< "$TARGET_PANES"
  for p in "${ADDR[@]}"; do
    # Trim whitespace
    p=$(echo "$p" | xargs)
    [ -z "$p" ] && continue
    echo "Sending to pane $p..."
    if ! send_to_pane "$p" "$MSG" "$FROM"; then
      SEND_OK=0
      FAILED_PANES="${FAILED_PANES:+$FAILED_PANES,}$p"
      echo "ERROR: Failed to send to pane $p" >&2
    else
      SENT_PANES="${SENT_PANES:+$SENT_PANES,}$p"
    fi
  done

    if [ "$NO_LOG" -ne 1 ] && [ -n "$FROM" ] && [ -n "$SENT_PANES" ]; then
      LOGGED_TARGETS=$(format_target_list "$SENT_PANES")
      "$SCRIPT_DIR/chat" "$FROM" "(to $LOGGED_TARGETS) $MSG" >/dev/null || SEND_OK=0
    fi
  fi
} 200>"$LOCKFILE"

if [ "$SEND_OK" -ne 1 ]; then
  [ -n "$FAILED_PANES" ] && echo "ERROR: Failed to send to panes: $FAILED_PANES" >&2
  exit 1
fi

echo "Sent to targets $(format_target_list "$SENT_PANES")"
