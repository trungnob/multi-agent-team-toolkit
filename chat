#!/bin/bash
# Team chatroom helper - posts a message and notifies other tmux panes
# Usage: ./chat [--sync] <name> <message>
# Example: ./chat Claude "Hey team, check the chatroom!"
# Example: ./chat --sync Gemini "I've updated the config."
#
# --sync automatically calls ./send --all <message> to notify all panes.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
[ ! -f "$SCRIPT_DIR/team.conf" ] && { echo "ERROR: team.conf not found in $SCRIPT_DIR" >&2; exit 1; }
source "$SCRIPT_DIR/team.conf"
TEAM_PANES="${PANE_LIST:-$PANE_CLAUDE $PANE_GEMINI $PANE_CODEX}"

SYNC=0
if [ "$1" = "--sync" ]; then
  SYNC=1
  shift
fi

CHATROOM="$SCRIPT_DIR/chatroom.md"
PROJECT_HASH=$(printf "%s" "$SCRIPT_DIR" | md5sum | cut -c1-8)
LOCKFILE="/tmp/team_${PROJECT_HASH}_chatroom.lock"
NAME="${1:-Anonymous}"
shift
MSG="$*"

if [ -z "$MSG" ]; then
  echo "Usage: ./chat [--sync] <name> <message>"
  echo "  e.g. ./chat --sync Claude 'Hey team, check the chatroom!'"
  exit 1
fi

# Prepend tmux info to the name if we are inside tmux.
if [ -n "$TMUX" ]; then
  CURRENT_SESSION=$(tmux display-message -p '#S' 2>/dev/null || true)
  CURRENT_PANE=$(tmux display-message -p '#P' 2>/dev/null || true)
  if [ -n "$CURRENT_SESSION" ] && [ "$CURRENT_PANE" != "" ]; then
    NAME="$NAME ($CURRENT_SESSION:$CURRENT_PANE)"
  fi
fi

TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
PREVIEW=$(printf '%s' "$MSG" | head -c 80)

# Acquire exclusive lock, write, release — atomic append
if ! (
  flock -w 10 200 || { echo "ERROR: Could not acquire chatroom lock"; exit 1; }
  printf '**[%s]** (%s): %s\n\n' "$NAME" "$TIMESTAMP" "$MSG" >> "$CHATROOM" || {
    echo "ERROR: Failed to append to chatroom" >&2
    exit 1
  }
) 200>"$LOCKFILE"; then
  exit 1
fi

# Determine the effective target window for notifications:
# 1. Use TMUX_TARGET from team.conf if set and not "auto".
# 2. If TMUX_TARGET is "auto", "current", or unset, use current tmux window.
EFFECTIVE_TARGET="$TMUX_TARGET"
if [ "$TMUX_TARGET" = "auto" ] || [ "$TMUX_TARGET" = "current" ] || [ -z "$TMUX_TARGET" ]; then
  if [ -n "$TMUX" ]; then
    EFFECTIVE_TARGET=$(tmux display-message -t "$TMUX_PANE" -p '#S:#I' 2>/dev/null || echo "$TMUX_TARGET")
  fi
fi

# Notify all panes via tmux display-message (ephemeral)
NOTIFY_FAILED=0
for pane in $TEAM_PANES; do
  if ! tmux display-message -t "$EFFECTIVE_TARGET.$pane" "[$NAME]: $PREVIEW" 2>/dev/null; then
    NOTIFY_FAILED=1
  fi
done

# If --sync is requested, call send --all (persistent notification to CLI input)
if [ "$SYNC" -eq 1 ]; then
  # We don't use --from here because 'send' itself will log to chatroom if --from is used,
  # causing duplicate entries. We just want the direct message delivery.
  if ! "$SCRIPT_DIR/send" --all "[$NAME]: $MSG" >/dev/null; then
    echo "ERROR: Sync delivery failed." >&2
    exit 1
  fi
fi

if [ "$NOTIFY_FAILED" -eq 0 ]; then
  echo "Posted to chatroom and notified team."
else
  echo "Posted to chatroom, but one or more tmux notifications failed." >&2
fi
