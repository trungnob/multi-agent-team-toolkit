#!/bin/bash
# Team chatroom helper - posts a message and notifies other tmux panes
# Usage: ./chat <name> <message>
# Example: ./chat Claude "Hey team, check the chatroom!"
#
# Uses flock to serialize writes to chatroom.md (prevents race conditions)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
[ ! -f "$SCRIPT_DIR/team.conf" ] && { echo "ERROR: team.conf not found in $SCRIPT_DIR" >&2; exit 1; }
source "$SCRIPT_DIR/team.conf"

CHATROOM="$SCRIPT_DIR/chatroom.md"
PROJECT_HASH=$(printf "%s" "$SCRIPT_DIR" | md5sum | cut -c1-8)
LOCKFILE="/tmp/team_${PROJECT_HASH}_chatroom.lock"
NAME="${1:-Anonymous}"
shift
MSG="$*"

if [ -z "$MSG" ]; then
  echo "Usage: ./chat <name> <message>"
  echo "  e.g. ./chat Claude 'Hey team, check the chatroom!'"
  exit 1
fi

TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
PREVIEW=$(printf '%s' "$MSG" | head -c 80)

# Acquire exclusive lock, write, release — atomic append
if ! (
  flock -w 10 200 || { echo "ERROR: Could not acquire chatroom lock"; exit 1; }
  printf '**[%s]** (%s): %s\n\n' "$NAME" "$TIMESTAMP" "$MSG" >> "$CHATROOM" || {
    echo "ERROR: Failed to append to chatroom" >&2
    exit 1
  }
) 200>"$LOCKFILE"; then
  exit 1
fi

# Notify all panes in the configured tmux target
NOTIFY_FAILED=0
for pane in $PANE_CLAUDE $PANE_GEMINI $PANE_CODEX; do
  if ! tmux display-message -t "$TMUX_TARGET.$pane" "[$NAME]: $PREVIEW" 2>/dev/null; then
    NOTIFY_FAILED=1
  fi
done

if [ "$NOTIFY_FAILED" -eq 0 ]; then
  echo "Posted to chatroom and notified team."
else
  echo "Posted to chatroom, but one or more tmux notifications failed." >&2
fi
